{
  "extends": "./tsconfig.base.json",
  "include": ["env.d.ts", "src/**/*", "vite.config.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/**/*.spec.ts", "src/**/**/*.test.ts"],
  "compilerOptions": {
    "composite": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "incremental": true, /* Save .tsbuildinfo files to allow for incremental compilation of projects. */
    /* Language and Environment */
    "lib": ["ES2022", "DOM"],                                        /* Specify a set of bundled library declaration files that describe the target runtime environment. */
       
  }
}
