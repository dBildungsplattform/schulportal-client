{
  "extends": "./tsconfig.base.json",
  "include": [
    "src/**/*.spec.ts",
    "test/**/*.ts",
    "eslint.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "lib": [
      "DOM",
      // from @tsconfig/node24
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],
    "types": ["@types/node", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "test/*": ["./test/*"]
    },
    "noEmit": true
  }
}
