{
  "name": "schulportal-client",
  "version": "1.0.4",
  "author": "Dataport AöR",
  "private": true,
  "type": "module",
  "license": "EUPL-1.2",
  "engines": {
    "node": "24.x",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "build": "npm run type-check && npm run build-only",
    "build-only": "vite build",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "format": "prettier --write src/",
    "check-format": "prettier --check **/*.ts",
    "generate-client": "openapi-generator-cli generate --generator-key backend --openapi-normalizer REFACTOR_ALLOF_WITH_PROPERTIES_ONLY=true",
    "lint": "eslint . --fix --ignore-pattern .gitignore",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vee-validate/yup": "^4.15.1",
    "axios": "^1.16.1",
    "date-fns": "^4.3.0",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.1.0",
    "vuetify": "^3.7.19",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@pinia/testing": "^1.0.3",
    "@rushstack/eslint-patch": "^1.11.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.5.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  }
}
